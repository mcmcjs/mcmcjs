{
  "name": "@mcmcjs/diagnostics",
  "version": "0.0.0",
  "description": "MCMC convergence diagnostics (R-hat, ESS, MCSE, HDI) for MCMC.js.",
  "keywords": [
    "mcmc",
    "bayesian",
    "diagnostics",
    "convergence",
    "rhat",
    "ess",
    "mcse",
    "hdi"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/diagnostics#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/diagnostics"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  }
}
