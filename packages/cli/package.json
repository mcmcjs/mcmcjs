{
  "name": "mcmcjs",
  "version": "0.15.0",
  "description": "Command-line tools for Bayesian modelling, MCMC inference, and post-inference diagnostics across probabilistic programming languages.",
  "keywords": [
    "mcmc",
    "bayesian",
    "bayesian-inference",
    "probabilistic-programming",
    "ppl",
    "inference",
    "diagnostics",
    "convergence",
    "posterior",
    "sampling",
    "cli",
    "command-line"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "bin": {
    "mcmc": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcmcjs/core": "workspace:*",
    "@mcmcjs/diagnostics": "workspace:*",
    "@mcmcjs/doodlebugs": "workspace:*",
    "@mcmcjs/engine": "workspace:*",
    "@mcmcjs/julia": "workspace:*",
    "@mcmcjs/plots": "workspace:*",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  }
}
