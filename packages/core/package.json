{
  "name": "@mcmcjs/core",
  "version": "0.8.0",
  "description": "Core data model and samples-file parsers for MCMC.js.",
  "keywords": [
    "mcmc",
    "bayesian",
    "inference",
    "arviz",
    "mcmcchains",
    "samples",
    "parser"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  }
}
