{
  "name": "doodleppl",
  "version": "0.4.2",
  "description": "Embed the DoodlePPL graphical model editor anywhere: a typed mount class over the compiled editor, with callbacks for graph state and generated BUGS/Stan code.",
  "keywords": [
    "doodleppl",
    "doodlebugs",
    "ppl",
    "bayesian",
    "graphical-models",
    "editor",
    "widget",
    "bugs",
    "stan"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/doodleppl-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/doodleppl-ui"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js",
      "default": "./dist/element.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && vite build --mode cdn && vue-tsc -p tsconfig.dts.json",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mcmcjs/doodleppl": "workspace:*",
    "@primevue/themes": "^4.4.1",
    "codemirror": "^5.65.19",
    "cytoscape": "^3.32.0",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-klay": "^3.1.4",
    "cytoscape-svg": "^0.4.0",
    "cytoscape-undo-redo": "^1.3.3",
    "pinia": "^3.0.2",
    "primeicons": "^7.0.0",
    "primevue": "^4.4.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/codemirror": "^5.60.17",
    "@types/cytoscape": "^3.21.9",
    "@vitejs/plugin-vue": "^5.2.3",
    "vite": "^6.4.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vue-tsc": "^2.2.8"
  }
}
