{
  "name": "@mcmcjs/plots-gl",
  "version": "0.2.7",
  "description": "Interactive WebGL renderers for MCMC plots (3D scatter, scatter-plot matrix, parallel coordinates), backed by regl.",
  "keywords": [
    "mcmc",
    "bayesian",
    "plots",
    "webgl",
    "regl",
    "scatter3d",
    "splom",
    "parallel-coordinates",
    "visualization"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/plots-gl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/plots-gl"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "regl": "^2.1.1"
  },
  "peerDependenciesMeta": {
    "regl": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcmcjs/core": "workspace:*",
    "@mcmcjs/diagnostics": "workspace:*",
    "@mcmcjs/plots": "workspace:*"
  },
  "devDependencies": {
    "regl": "^2.1.1"
  }
}
