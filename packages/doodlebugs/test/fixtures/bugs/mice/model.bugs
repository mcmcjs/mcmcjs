model {
  for (i in 1:M) {
    for (j in 1:N) {
      t[i,j] ~ dweib(r, mu[i])C(t.cen[i, j],)
    }
    beta[i] ~ dnorm(0.0, 0.001)
    mu[i] <- exp(beta[i])
    median[i] <- pow(log(2) * exp(-beta[i]), 1 / r)
  }
  r ~ dunif(0.1, 10)
  veh.control <- beta[2] - beta[1]
  test.sub <- beta[3] - beta[1]
  pos.control <- beta[4] - beta[1]
}