{
  "name": "@mcmcjs/plots",
  "version": "0.6.0",
  "description": "Diagnostic plots (trace, density, forest, rank, ...) for MCMC.js, rendered to the terminal, SVG, or a self-contained HTML page.",
  "keywords": [
    "mcmc",
    "bayesian",
    "plots",
    "visualization",
    "trace",
    "forest",
    "diagnostics"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/plots#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/plots"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "vendor:uplot": "node scripts/vendor-uplot.mjs"
  },
  "dependencies": {
    "@mcmcjs/charts": "workspace:*",
    "@mcmcjs/core": "workspace:*",
    "@mcmcjs/diagnostics": "workspace:*"
  },
  "devDependencies": {
    "uplot": "^1.6.32"
  }
}
