{
  "name": "@mcmcjs/doodleppl",
  "version": "0.2.0",
  "description": "Turn a DoodlePPL graph into probabilistic model code (BUGS/JuliaBUGS, Stan); the shared codegen for the DoodlePPL editor and the MCMC.js CLI.",
  "keywords": [
    "doodleppl",
    "doodlebugs",
    "ppl",
    "bugs",
    "juliabugs",
    "stan",
    "bayesian",
    "graphical-models",
    "codegen"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/doodleppl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/doodleppl"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./stan": {
      "types": "./dist/codegen/stan.d.ts",
      "import": "./dist/codegen/stan.js",
      "require": "./dist/codegen/stan.cjs"
    },
    "./graph.schema.json": "./dist/graph.schema.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
