model {
  for (i in 1:Num) {
    mu[i] ~ dnorm(0.0, 1.0E-5)
    delta[i] ~ dnorm(d, tau)
    rc[i] ~ dbin(pc[i], nc[i])
    rt[i] ~ dbin(pt[i], nt[i])
    pc[i] <- logistic(mu[i])
    pt[i] <- logistic(mu[i] + delta[i])
  }
  d ~ dnorm(0.0, 1.0E-6)
  tau ~ dgamma(0.001, 0.001)
  delta.new ~ dnorm(d, tau)
  sigma <- 1 / sqrt(tau)
}