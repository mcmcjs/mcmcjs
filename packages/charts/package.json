{
  "name": "@mcmcjs/charts",
  "version": "0.5.0",
  "description": "A dependency-free plotting engine: render line, scatter, bar, interval, and density plots to the terminal (braille/block/ASCII) or SVG from one figure model.",
  "keywords": [
    "charts",
    "plot",
    "terminal",
    "braille",
    "unicode",
    "ascii",
    "svg",
    "visualization",
    "cli"
  ],
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs/tree/main/packages/charts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "import": "./dist/dom/index.js",
      "require": "./dist/dom/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "uplot": "^1.6.32"
  },
  "peerDependenciesMeta": {
    "uplot": {
      "optional": true
    }
  },
  "devDependencies": {
    "uplot": "^1.6.32"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  }
}
