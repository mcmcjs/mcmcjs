---
import { Code } from "astro:components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths";
import plotSpecs from "../plots/eight-schools.json";

type PlotSpec = {
	key: string;
	label: string;
	mode: "uplot" | "svg";
	svg?: string;
};
const plots = plotSpecs as PlotSpec[];

const siteOrigin = Astro.site ?? Astro.url;
const appUrl = new URL(withBase("/"), siteOrigin).href;
const installUrl = new URL(withBase("/docs/install/"), siteOrigin).href;
const diagnoseUrl = new URL(withBase("/docs/guides/diagnose/"), siteOrigin)
	.href;

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "MCMC.js",
		applicationCategory: "DeveloperApplication",
		operatingSystem: "Linux, macOS, Windows",
		description:
			"Command-line tools for Bayesian modelling, MCMC inference, and post-inference diagnostics across probabilistic programming languages.",
		url: appUrl,
		downloadUrl: "https://github.com/mcmcjs/mcmcjs/releases",
		author: {
			"@type": "Person",
			name: "Shravan Goswami",
			url: "https://shravangoswami.com",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "What is MCMC.js?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "MCMC.js is a set of command-line tools for Bayesian modelling, MCMC inference, and post-inference diagnostics across probabilistic programming languages.",
				},
			},
			{
				"@type": "Question",
				name: "How do I install MCMC.js?",
				acceptedAnswer: {
					"@type": "Answer",
					text: `Install the mcmc CLI globally with npm, then run mcmc setup. See ${installUrl}.`,
				},
			},
			{
				"@type": "Question",
				name: "Does it run the inference itself?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "The CLI is a thin orchestrator. Inference steps run a Julia subprocess, while diagnostics and the rest of the workflow are pure TypeScript.",
				},
			},
			{
				"@type": "Question",
				name: "How do I check convergence?",
				acceptedAnswer: {
					"@type": "Answer",
					text: `Run mcmc diagnose to compute R-hat, ESS, MCSE, and HDI over your samples. See ${diagnoseUrl}.`,
				},
			},
		],
	},
];

const eightSchoolsModel = `using Turing

@model function eight_schools(y, sigma)
    J = length(y)
    mu ~ Normal(0, 5)
    tau ~ truncated(Cauchy(0, 5); lower = 0)
    theta ~ filldist(Normal(mu, tau), J)
    for j in 1:J
        y[j] ~ Normal(theta[j], sigma[j])
    end
end

build_model(data) = eight_schools(data.y, data.sigma)`;

const eightSchoolsData = `y,sigma
28,15
8,10
-3,16
7,11
-1,9
1,11
18,10
12,18`;

const eightSchoolsRun = `$ mcmc run eight_schools.jl --data data.csv
Fitting eight_schools.jl with Turing.jl (NUTS, 4 chains x 1000 draws + 1000 warmup) on Julia 1.12.6...
ok: run 20260626-062103-35158c (19.8 s, Julia 1.12.6) saved to .mcmc

variable  mean   std    r_hat  ess_bulk  ess_tail  mcse   hdi
--------  -----  -----  -----  --------  --------  -----  ----------------
mu        4.748  3.219  1.042  114       1250      0.319  [-1.604, 10.218]
tau       3.436  3.375  1.359  17        15        0.498  [0.310, 9.348]
theta[1]  6.447  5.424  1.186  578       983       0.198  [-3.527, 16.557]
theta[2]  5.339  4.501  1.101  350       1279      0.202  [-3.439, 13.942]
theta[3]  4.312  5.244  1.047  153       1185      0.383  [-6.738, 12.959]
theta[4]  5.192  4.664  1.094  304       1534      0.239  [-3.846, 14.176]
theta[5]  3.962  4.562  1.043  110       1208      0.449  [-5.701, 11.438]
theta[6]  4.378  4.658  1.082  190       1622      0.325  [-4.396, 13.254]
theta[7]  6.530  4.773  1.188  579       675       0.183  [-2.170, 15.820]
theta[8]  5.309  5.205  1.089  338       1464      0.180  [-4.724, 15.047]

divergences: 503
not converged (R-hat <= 1.01, ESS >= 400, divergences <= 0)`;

// Real terminal output of `mcmc run` on the scaffolded demo model.
const runTranscript = `$ mcmc run demo/model.jl
using data from demo/data.csv (pass --data to override)
Fitting model.jl with Turing.jl (NUTS, 4 chains x 1000 draws + 1000 warmup) on Julia 1.12.6...
sampling chain 1 of 4: 100%
sampling chain 2 of 4: 100%
sampling chain 3 of 4: 100%
sampling chain 4 of 4: 100%
ok: run 20260626-060443-61ae20 (22.5 s, Julia 1.12.6) saved to demo/.mcmc

variable  mean   std    r_hat  ess_bulk  ess_tail  mcse   hdi
--------  -----  -----  -----  --------  --------  -----  --------------
alpha     2.047  0.251  1.002  1414      1376      0.007  [1.580, 2.498]
beta      2.991  0.041  1.003  1420      1320      0.001  [2.917, 3.068]
sigma     0.346  0.111  1.002  1385      1499      0.003  [0.189, 0.547]

divergences: 0
converged (R-hat <= 1.01, ESS >= 400, divergences <= 0)`;
---

<BaseLayout
	title="MCMC.js"
	description="Command-line tools for Bayesian modelling, MCMC inference, and post-inference diagnostics."
	structuredData={structuredData}
>
	<section class="hero">
		<h1>Bayesian inference, from one command line.</h1>
		<div class="actions">
			<a class="button" href={withBase('/docs/install/')}>Install MCMC.js</a>
			<a class="button secondary" href={withBase('/docs/')}>Read the docs</a>
		</div>
		<div class="hero-demo">
			<div class="terminal-chrome">
				<span class="chrome-dots">
					<span></span><span></span><span></span>
				</span>
				<span class="chrome-title">mcmc — zsh</span>
			</div>
			<div class="hero-terminal-body" aria-label="Example mcmc run session">
				<pre class="hero-transcript">{runTranscript}</pre>
			</div>
		</div>
		<p class="hero-copy">
			<code>mcmc</code> drives Bayesian modelling end to end: provision a runtime, fit a
			model, and run post-inference diagnostics. Stages compose through one declarative
			spec file in and one samples file out, so each step stays small and predictable.
		</p>
	</section>

	<section class="section example">
		<div class="section-header">
			<h2>Eight schools, end to end.</h2>
			<p>
				The textbook hierarchical model, and a textbook trap. Run it, and the
				diagnostics flag the funnel the centered parameterization hides: high
				R-hat, low ESS, hundreds of divergences. Drag to zoom any plot.
			</p>
		</div>
		<div class="demo-split">
			<div class="demo-left">
				<div class="tabs" data-tabs>
					<div class="tablist" role="tablist" aria-label="Model source">
						<button class="tab is-active" type="button" role="tab" data-tab="model">eight_schools.jl</button>
						<button class="tab" type="button" role="tab" data-tab="data">data.csv</button>
					</div>
					<div class="tabpanel is-active" data-panel="model">
						<Code code={eightSchoolsModel} lang="julia" themes={{ light: "github-light", dark: "github-dark" }} defaultColor={false} />
					</div>
					<div class="tabpanel" data-panel="data">
						<Code code={eightSchoolsData} lang="csv" themes={{ light: "github-light", dark: "github-dark" }} defaultColor={false} />
					</div>
				</div>
				<div class="run-it">
					<span class="run-it-label">Run it</span>
					<pre class="run-transcript">{eightSchoolsRun}</pre>
				</div>
			</div>
			<div class="demo-right">
				<div class="tabs" data-tabs data-plot-tabs>
					<div class="tablist" role="tablist" aria-label="Diagnostic plots">
						{plots.map((p, i) => (
							<button class:list={["tab", { "is-active": i === 0 }]} type="button" role="tab" data-tab={p.key}>{p.label}</button>
						))}
					</div>
					<div class="plot-stage">
						{plots.map((p, i) => (
							<div
								class:list={["tabpanel", "plot-panel", { "is-active": i === 0 }]}
								data-panel={p.key}
								data-mode={p.mode}
								set:html={p.mode === "svg" ? p.svg : ""}
							/>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-header">
			<h2>A thin, composable workflow.</h2>
			<p>
				<code>mcmc</code> orchestrates probabilistic programming languages without
				becoming a framework. One spec in, one samples file out.
			</p>
		</div>
		<div class="feature-grid">
			<div class="feature">
				<h3>Fit anywhere</h3>
				<p>Run inference through a managed Julia runtime, with the CLI as a thin TypeScript orchestrator.</p>
			</div>
			<div class="feature">
				<h3>Diagnostics built in</h3>
				<p>Compute R-hat, ESS, MCSE, and HDI over your samples to judge convergence with confidence.</p>
			</div>
			<div class="feature">
				<h3>Reproducible runs</h3>
				<p>A declarative spec file in and a samples file out keep every run inspectable and repeatable.</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section-header">
			<h2>Start in one line.</h2>
			<p>Install the CLI from npm, then provision the runtime with <code>mcmc setup</code>.</p>
		</div>
		<div class="install-strip">
			<div>
				<strong>npm global install</strong>
				<span>Installs the <code>mcmc</code> binary. Run <code>mcmc setup</code> once to provision Julia via juliaup.</span>
			</div>
			<pre><code>npm i -g mcmcjs</code></pre>
			<a class="button secondary" href={withBase('/docs/quickstart/')}>Quickstart</a>
		</div>
	</section>

	<section class="section">
		<div class="section-header">
			<h2>Documentation.</h2>
			<p>Focused pages for installation, running inference, diagnostics, the CLI reference, and internals.</p>
		</div>
		<div class="docs-grid">
			<a class="doc-link" href={withBase('/docs/install/')}>
				<h3>Installation</h3>
				<p>Install the CLI and provision the Julia runtime with a single setup command.</p>
			</a>
			<a class="doc-link" href={withBase('/docs/guides/run/')}>
				<h3>Run inference</h3>
				<p>Fit a model from a spec file and produce a samples file you can diagnose and plot.</p>
			</a>
			<a class="doc-link" href={withBase('/docs/guides/diagnose/')}>
				<h3>Diagnose convergence</h3>
				<p>Read R-hat, ESS, MCSE, and HDI to judge whether your chains have converged.</p>
			</a>
		</div>
	</section>

	<section class="section">
		<div class="section-header">
			<h2>FAQ</h2>
			<p>Quick answers for search engines and humans.</p>
		</div>
		<div class="feature-grid">
			<div class="feature">
				<h3>What is MCMC.js?</h3>
				<p>Command-line tools for Bayesian modelling, MCMC inference, and post-inference diagnostics across PPLs.</p>
			</div>
			<div class="feature">
				<h3>Does it run the inference?</h3>
				<p>The CLI is a thin orchestrator. Inference runs in a Julia subprocess; diagnostics are pure TypeScript.</p>
			</div>
			<div class="feature">
				<h3>How do I check convergence?</h3>
				<p>Run <code>mcmc diagnose</code> to compute R-hat, ESS, MCSE, and HDI over your samples.</p>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	import uPlot from "uplot";
	import "uplot/dist/uPlot.min.css";
	import rawSpecs from "../plots/eight-schools.json";

	type PlotItem = {
		key: string;
		mode: string;
		// biome-ignore lint/suspicious/noExplicitAny: function-free uPlot spec from @mcmcjs/plots
		spec?: any;
	};

	const specs = rawSpecs as PlotItem[];
	const AXIS = "#8a8a8a";
	const GRID = "rgba(140, 140, 140, 0.18)";
	const byKey = new Map(specs.map((s) => [s.key, s]));
	const mounted = new WeakSet<HTMLElement>();

	function pathFor(s: { paths?: string }) {
		const paths = uPlot.paths as Record<string, (o: unknown) => unknown>;
		if (s.paths === "bars" && paths.bars) return paths.bars({ size: [0.85, Number.POSITIVE_INFINITY] });
		if (s.paths === "stepped" && paths.stepped) return paths.stepped({ align: 1 });
		return null;
	}

	// biome-ignore lint/suspicious/noExplicitAny: spec mirrors @mcmcjs/plots UplotSpec
	function mountPlot(panel: HTMLElement, spec: any) {
		const series: Record<string, unknown>[] = [{}];
		for (const s of spec.series) {
			const o: Record<string, unknown> = { label: s.label, stroke: s.stroke, width: s.width ?? 1.5 };
			if (s.fill) o.fill = s.fill;
			if (s.dash) o.dash = s.dash;
			const path = pathFor(s);
			if (path) {
				o.paths = path;
				o.points = { show: false };
			}
			series.push(o);
		}
		const width = () => Math.max(280, panel.clientWidth - 4);
		const axis = { stroke: AXIS, grid: { stroke: GRID }, ticks: { stroke: AXIS } };
		const opts = {
			width: width(),
			height: 300,
			scales: { x: { time: false } },
			axes: [
				{ ...axis, label: spec.xLabel || "" },
				{ ...axis, label: spec.yLabel || "" },
			],
			series,
			legend: { show: true },
			cursor: { drag: { x: true, y: true, uni: 12 } },
		} as unknown as uPlot.Options;
		const u = new uPlot(opts, spec.data as uPlot.AlignedData, panel);
		window.addEventListener("resize", () => u.setSize({ width: width(), height: 300 }));
	}

	function ensurePlot(panel: HTMLElement) {
		if (mounted.has(panel) || panel.dataset.mode !== "uplot") return;
		const spec = byKey.get(panel.dataset.panel ?? "")?.spec;
		if (!spec) return;
		mounted.add(panel);
		mountPlot(panel, spec);
	}

	for (const group of document.querySelectorAll<HTMLElement>("[data-tabs]")) {
		const tabs = [...group.querySelectorAll<HTMLElement>("[data-tab]")];
		const panels = [...group.querySelectorAll<HTMLElement>("[data-panel]")];
		for (const tab of tabs) {
			tab.addEventListener("click", () => {
				for (const t of tabs) t.classList.toggle("is-active", t === tab);
				for (const panel of panels) {
					const on = panel.dataset.panel === tab.dataset.tab;
					panel.classList.toggle("is-active", on);
					if (on) ensurePlot(panel);
				}
			});
		}
	}

	for (const panel of document.querySelectorAll<HTMLElement>(".plot-panel.is-active")) ensurePlot(panel);
</script>
