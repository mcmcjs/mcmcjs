---
interface Props {
	class?: string;
}

const className = Astro.props.class ?? "logo-mark";
---

<svg class={className} viewBox="0 0 100 100" role="img" aria-label="MCMC.js">
	<polyline
		points="14,82 38,60 50,28 62,60 86,82"
		fill="none"
		stroke="var(--logo-navy)"
		stroke-width="3.6"
		stroke-linejoin="round"
		stroke-linecap="round"
	/>
	<polyline
		points="38,60 50,28 62,60"
		fill="none"
		stroke="var(--logo-purple)"
		stroke-width="3.6"
		stroke-linejoin="round"
		stroke-linecap="round"
	/>
	<circle cx="14" cy="82" r="6" fill="var(--logo-navy)" />
	<circle cx="38" cy="60" r="6" fill="var(--logo-navy)" />
	<circle cx="50" cy="28" r="7" fill="var(--logo-purple)" />
	<circle cx="62" cy="60" r="6" fill="var(--logo-purple)" />
	<circle cx="86" cy="82" r="6" fill="var(--logo-navy)" />
</svg>
