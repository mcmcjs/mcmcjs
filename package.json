{
  "name": "mcmcjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the MCMC.js command-line tools for Bayesian inference and diagnostics.",
  "license": "MIT",
  "author": {
    "name": "Shravan Goswami",
    "email": "contact@shravangoswami.com",
    "url": "https://shravangoswami.com"
  },
  "homepage": "https://github.com/mcmcjs/mcmcjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcmcjs/mcmcjs.git"
  },
  "bugs": {
    "url": "https://github.com/mcmcjs/mcmcjs/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "check": "biome check .",
    "format": "biome check --write .",
    "verify": "pnpm check && pnpm typecheck && pnpm test && pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24",
    "@vitest/coverage-v8": "4.1.8",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
